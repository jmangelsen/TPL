{
  "entities": {
    "subscriber": {
      "title": "Subscriber",
      "description": "A person who has subscribed to the newsletter.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the subscriber."
        },
        "date": {
          "type": "string",
          "format": "date-time",
          "description": "The date and time the subscription was created."
        }
      },
      "required": ["email", "date"]
    },
    "user": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the user."
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user"],
          "description": "The role of the user."
        },
        "isSubscribed": {
          "type": "boolean",
          "description": "Whether the user has an active subscription."
        }
      },
      "required": ["email", "role"]
    },
    "savedResearch": {
      "title": "Saved Research",
      "description": "A research item saved by a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["article", "analysis", "visualization"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "content", "type", "timestamp"]
    },
    "companyNews": {
      "title": "Company News",
      "description": "News articles related to a tracked company.",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "headline": { "type": "string" },
        "source": { "type": "string" },
        "url": { "type": "string" },
        "publishedAt": { "type": "string", "format": "date-time" },
        "summary": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["companyId", "headline", "source", "url", "publishedAt", "createdAt"]
    },
    "sectorSpend": {
      "title": "Sector Spend",
      "description": "Evidence drawer data for a specific sector.",
      "type": "object",
      "properties": {
        "sectorId": { "type": "string" },
        "totalSpend": { "type": "number" },
        "companies": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "entity": { "type": "string" },
              "spend": { "type": "number" }
            },
            "required": ["entity", "spend"]
          }
        },
        "narrative": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["sectorId", "totalSpend", "companies", "narrative", "updatedAt"]
    },
    "siteError": {
      "title": "Site Error",
      "description": "An error that occurred on the site.",
      "type": "object",
      "properties": {
        "message": { "type": "string" },
        "stack": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "url": { "type": "string" }
      },
      "required": ["message", "timestamp", "url"]
    }
  },
  "firestore": {
    "/subscribers/{subscriberId}": {
      "schema": "subscriber",
      "description": "Collection of all newsletter subscribers."
    },
    "/users/{userId}": {
      "schema": "user",
      "description": "Collection of application users and their roles."
    },
    "/savedResearch/{researchId}": {
      "schema": "savedResearch",
      "description": "Collection of research items saved by users."
    },
    "/company_news/{newsId}": {
      "schema": "companyNews",
      "description": "Collection of news articles related to tracked companies."
    },
    "/sector_spend/{sectorId}": {
      "schema": "sectorSpend",
      "description": "Collection of sector-specific evidence drawer data."
    },
    "/site_errors/{errorId}": {
      "schema": "siteError",
      "description": "Collection of site errors logged by the application."
    }
  }
}
